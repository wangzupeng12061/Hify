# Copy this file to .env for local release verification.
# Production values must come from the deployment platform or secret manager.

COMPOSE_PROJECT_NAME=hify

POSTGRES_DB=hify
POSTGRES_USER=hify
POSTGRES_PASSWORD=hify_dev_password

HIFY_DATABASE_URL=postgresql+psycopg://hify:hify_dev_password@postgres:5432/hify
HIFY_DATABASE_ECHO=false
HIFY_REDIS_URL=redis://redis:6379/0
HIFY_CELERY_BROKER_URL=redis://redis:6379/0
HIFY_CELERY_RESULT_BACKEND_URL=
HIFY_CELERY_TASK_SOFT_TIME_LIMIT_SECONDS=300
HIFY_CELERY_TASK_HARD_TIME_LIMIT_SECONDS=360
HIFY_CELERY_VISIBILITY_TIMEOUT_SECONDS=3600

# Local-only Fernet key for verification. Replace in production.
# Generate a new key with:
#   cd backend && uv run python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
HIFY_PROVIDER_CREDENTIAL_ENCRYPTION_KEY=IIFP4cn3UzmCerIx1zafy8i5emQWIXyBh5TLp96R0Ig=
HIFY_PROVIDER_CREDENTIAL_KEY_VERSION=1

NEXT_PUBLIC_HIFY_API_BASE_URL=/api
